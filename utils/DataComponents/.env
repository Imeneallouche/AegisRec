# Elasticsearch
ES_HOSTS=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme

# Detection
POLLING_INTERVAL=60
LOOKBACK_MINUTES=5
BATCH_SIZE=1000
MAX_DOCUMENTS=10000

# Similarity thresholds
EXACT_MATCH_THRESHOLD=1.0
REGEX_MATCH_THRESHOLD=0.9
TOKEN_OVERLAP_THRESHOLD=0.7
EMBEDDING_THRESHOLD=0.8

# Assets
ASSET_REGISTER_PATH=assets.json
ASSET_CORRELATION_FIELDS=host.ip,source.ip,destination.ip,host.name,agent.name

# State
STATE_FILE=detection_state.json
OUTPUT_FILE=detections.json

DEDUP_WINDOW_HOURS=24


# Index Patterns (matching our new indices)
# WINDOWS_INDEX=grfics-windows-*
# LINUX_INDEX=grfics-logs-*,grfics-container-*,grfics-security-*
# MACOS_INDEX=grfics-macos-*
# NETWORK_INDEX=grfics-network-*
# CLOUD_INDEX=grfics-cloud-*
# CONTAINER_INDEX=grfics-container-*
# SECURITY_INDEX=grfics-security-*
# APPLICATION_INDEX=grfics-logs-*
# ICS_INDEX=grfics-ics-*
# ALL_LOGS_INDEX=grfics-*


WINDOWS_INDEX=grfics-*
LINUX_INDEX=grfics-*
MACOS_INDEX=grfics-*
NETWORK_INDEX=grfics-*
CLOUD_INDEX=grfics-*
CONTAINER_INDEX=grfics-*
SECURITY_INDEX=grfics-*
APPLICATION_INDEX=grfics-*
ICS_INDEX=grfics-*
ALL_LOGS_INDEX=grfics-*


# ICS Specific Patterns
ICS_PLC_INDEX=grfics-ics-*
ICS_HMI_INDEX=grfics-ics-*
ICS_NETWORK_INDEX=grfics-network-*


# Advanced Features
ENABLE_EMBEDDINGS=true
MIN_TOKEN_OVERLAP=0.5
ENABLE_ICS_SPECIFIC=true

# Asset Register
ASSET_FILE=assets.json