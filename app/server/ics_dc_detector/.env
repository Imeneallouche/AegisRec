# ─── Elasticsearch ─────────────────────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_USER=elastic
ES_PASS=changeme
ES_SSL=false
ES_SSL_VERIFY=false
ES_CA_CERTS=                    # path to CA cert bundle, empty = system default
# Index pattern – supports wildcards.  Separate multiple patterns with comma.
ES_INDEX_PATTERN=linux-auth-*,auditd-*,syslog-*,ics-*,ics-suricata-*,ics-network-*,ics-network-share-*,ics-alarms-*,ics-process-history-*,hmi-*,plc-*
# ─── Detection engine ──────────────────────────────────────────────────────────
DC_DIR=./datacomponents          # directory of DataComponent JSON files
SIMILARITY_THRESHOLD=0.45        # minimum score for Stage-3 embedding match
EMBEDDING_MODEL=all-MiniLM-L6-v2 # HuggingFace model; swap with cybersec fine-tune
TEMPORAL_WINDOW_SECONDS=60       # window for cross-DC correlation boost
CORRELATION_BOOST=0.15           # score boost for temporal correlation hits

# ─── Runtime mode ──────────────────────────────────────────────────────────────
# MODE: polling | batch | streaming
MODE=polling
POLL_INTERVAL_SECONDS=15
LOOKBACK_WINDOW_MINUTES=60        # polling: how far back each poll looks
BATCH_START=                     # ISO8601, e.g. 2024-01-01T00:00:00Z
BATCH_END=                       # ISO8601
BATCH_PAGE_SIZE=500

# ─── State / deduplication backend ─────────────────────────────────────────────
# STATE_BACKEND: file | redis
STATE_BACKEND=file
STATE_FILE_PATH=./state/cursor.json
REDIS_URL=redis://localhost:6379/0
STATE_KEY_PREFIX=ics_dc_detector

# ─── Output sinks (comma-separated list) ───────────────────────────────────────
# SINKS: stdout, file, kafka, webhook
SINKS=stdout,file
ALERT_FILE_PATH=./output/alerts.ndjson

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ics-dc-alerts
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# HTTP Webhook
WEBHOOK_URL=
WEBHOOK_AUTH_HEADER=
WEBHOOK_TIMEOUT_SECONDS=5

# ─── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
PROMETHEUS_PORT=8000
HEALTHCHECK_PORT=8001
SERVICE_NAME=ics-dc-detector
